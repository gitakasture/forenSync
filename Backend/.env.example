# ─────────────────────────────────────────────
# ForenSync Backend — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ─────────────────────────────────────────────

# Flask environment: "development" | "testing" | "production"
FLASK_ENV=development

# Flask app entry point (used by `flask run`)
FLASK_APP=run.py

# Secret key used for session signing — use a long random string in production
SECRET_KEY=change-this-to-a-random-secret-key

# Comma-separated list of allowed CORS origins
# Default (if unset): http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Absolute or relative path to the uploads directory
# Default (if unset): ./uploads
UPLOAD_FOLDER=./uploads

# Server host and port (used by run.py)
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5000
